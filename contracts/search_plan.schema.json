{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/evidence-flow/search_plan.schema.json",
  "title": "SearchPlan",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "query_id",
      "query_text",
      "target_intent",
      "research_track",
      "chat_label",
      "research_question",
      "task_prompt",
      "priority",
      "domain_layer",
      "hierarchy_level",
      "thematic_axis",
      "source_hints",
      "expected_formats",
      "target_parameters",
      "coverage_target"
    ],
    "additionalProperties": false,
    "properties": {
      "query_id": { "type": "string", "minLength": 1 },
      "query_text": { "type": "string", "minLength": 1 },
      "target_intent": {
        "type": "string",
        "enum": ["dataset_discovery", "contextual_intelligence", "academic_knowledge"]
      },
      "research_track": { "type": "string", "minLength": 1 },
      "chat_label": { "type": "string", "minLength": 1 },
      "research_question": { "type": "string", "minLength": 1 },
      "task_prompt": { "type": "string", "minLength": 1 },
      "priority": { "type": "string", "enum": ["high", "medium", "low"] },
      "domain_layer": { "type": "string", "minLength": 1 },
      "hierarchy_level": {
        "type": "string",
        "enum": ["macro", "meso", "bridge", "micro", "custom"]
      },
      "thematic_axis": { "type": "string", "minLength": 1 },
      "source_hints": {
        "type": "array",
        "items": { "type": "string" }
      },
      "expected_formats": {
        "type": "array",
        "items": { "type": "string" }
      },
      "target_parameters": {
        "type": "array",
        "items": { "type": "string" }
      },
      "coverage_target": {
        "type": "object",
        "required": ["years", "required"],
        "additionalProperties": false,
        "properties": {
          "years": { "type": "integer", "minimum": 0 },
          "required": { "type": "boolean" }
        }
      }
    }
  }
}

